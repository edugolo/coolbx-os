# Coolbx OS — GNOME desktop defaults (Focus-dark + mint)
[org/gnome/desktop/interface]
color-scheme='prefer-dark'
accent-color='green'
font-name='Inter 11'
document-font-name='Inter 11'
monospace-font-name='Source Code Pro 10'
clock-show-weekday=true

[org/gnome/desktop/background]
picture-uri='file:///usr/share/backgrounds/coolbx/coolbx-dark.png'
picture-uri-dark='file:///usr/share/backgrounds/coolbx/coolbx-dark.png'
picture-options='zoom'
primary-color='#141210'
secondary-color='#141210'

[org/gnome/desktop/screensaver]
picture-uri='file:///usr/share/backgrounds/coolbx/coolbx-login.png'
primary-color='#141210'

[org/gnome/shell]
favorite-apps=['chromium-browser.desktop', 'org.gnome.Nautilus.desktop', 'org.gnome.Calculator.desktop', 'coolbx-toetsmodus.desktop']

[org/gnome/desktop/wm/preferences]
button-layout='appmenu:minimize,maximize,close'
