#!/usr/bin/env python3
"""Vergrendel/ontgrendel VT-switching op kernel-niveau (S3).

Sway geeft Ctrl+Alt+Fn door aan de kernel-VT-laag; alleen daar kun je het blokkeren.
VT_LOCKSWITCH/VT_UNLOCKSWITCH werken op de console en blokkeren ALLE VT-switches
(ook programmatisch), dus altijd eerst 'unlock' vóór een chvt.

Gebruik: coolbx-vt-lock lock|unlock   (vereist root)
"""
import fcntl
import sys

VT_LOCKSWITCH = 0x560B
VT_UNLOCKSWITCH = 0x560C

op = sys.argv[1] if len(sys.argv) > 1 else "lock"
with open("/dev/tty0", "wb") as fd:
    fcntl.ioctl(fd, VT_LOCKSWITCH if op == "lock" else VT_UNLOCKSWITCH)
