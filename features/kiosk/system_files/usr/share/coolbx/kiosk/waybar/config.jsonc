{
  "layer": "top",
  "position": "top",
  "height": 32,
  "spacing": 0,
  "margin-top": 0,
  "modules-left": ["custom/brand"],
  "modules-center": ["clock"],
  "modules-right": ["network", "battery", "custom/exit"],

  "custom/brand": {
    "format": "coolbx <span foreground='#e8902a'>focus</span>",
    "tooltip": false
  },
  "clock": {
    "format": "{:L%a %e %b  %H:%M}",
    "locale": "nl_BE.UTF-8",
    "tooltip": false
  },
  "network": {
    "format-wifi": "wifi {signalStrength}%",
    "format-ethernet": "verbonden",
    "format-disconnected": "geen netwerk",
    "tooltip": false
  },
  "battery": {
    "format": "batterij {capacity}%",
    "format-charging": "laden {capacity}%",
    "format-full": "batterij vol",
    "tooltip": false
  },
  "custom/exit": {
    "format": "Sessie afsluiten",
    "on-click": "/usr/bin/coolbx-kiosk-exit",
    "tooltip": false
  }
}