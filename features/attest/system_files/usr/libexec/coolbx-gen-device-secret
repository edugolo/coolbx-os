#!/usr/bin/env bash
# Coolbx OS — genereer het per-toestel HMAC-secret (Fase: attestatie, ADR-0013).
# Draait als first-boot oneshot (root). Het secret is ROOT-ONLY (0600) zodat de leerling-sessie
# het nooit kan lezen; enkel de root-daemon coolbx-attestd tekent ermee.
# In productie wordt dit secret bij ENROLLMENT uitgedeeld + in de Focus-server-allowlist gezet
# (deviceId→secret); deze lokale generatie is de pilot/dev-vorm.
set -euo pipefail

SECRET=/etc/coolbx/device-secret
install -d -m0755 /etc/coolbx

if [ -s "$SECRET" ]; then
  echo "coolbx-gen-device-secret: secret bestaat al — niets te doen"
  exit 0
fi

umask 077
head -c32 /dev/urandom | base64 -w0 > "$SECRET"
chmod 0600 "$SECRET"
chown root:root "$SECRET"
echo "coolbx-gen-device-secret: nieuw per-toestel-secret aangemaakt ($SECRET, 0600 root)"
