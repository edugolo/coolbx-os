#!/usr/bin/env bash
# Coolbx OS — per-toestel HMAC-secret: genereren + TPM2-sealen (ADR-0013, B3.e F-03-006).
# Draait als boot-oneshot zolang er geen sealed credential is (root).
#
# Tier 1 (TPM2 aanwezig): het secret leeft UITSLUITEND TPM2-sealed op schijf
#   (/etc/coolbx/device-secret.cred, systemd-creds). Een uitgelezen/gestolen
#   schijf levert niets bruikbaars op: alleen ditzelfde toestel (deze TPM) kan
#   het credential openen. Een bestaand plain secret wordt in-place geseald
#   (zelfde waarde → de bestaande server-registratie blijft geldig) en daarna
#   vernietigd.
# Tier 2 (geen TPM2): plain file 0600 root (pilot-vorm van ADR-0013). De
#   Focus-server kan deze klasse voor examens weren met
#   EXAM_MIN_DEVICE_CLASS=tpm-sealed.
#
# De toestelklasse staat in /etc/coolbx/device-class ('tpm-sealed'|'file-secret')
# — informatief voor enrollment (coolbx-enroll-info); de server vertrouwt enkel
# de klasse in zíjn eigen register (gezet bij registratie).
set -euo pipefail

SECRET=/etc/coolbx/device-secret
CRED=/etc/coolbx/device-secret.cred
CLASS=/etc/coolbx/device-class
CRED_NAME=coolbx-device-secret
install -d -m0755 /etc/coolbx

if [ -s "$CRED" ]; then
  echo "coolbx-gen-device-secret: sealed credential bestaat al — niets te doen"
  [ -s "$CLASS" ] || { echo tpm-sealed > "$CLASS"; chmod 0644 "$CLASS"; }
  exit 0
fi

umask 077
if systemd-creds has-tpm2 >/dev/null 2>&1; then
  # Bewust GEEN PCR-binding (--tpm2-pcrs=""): het credential is aan de TPM-chip
  # (dus aan het toestel) gebonden, niet aan de firmware-meetstand — een
  # firmware/SecureBoot-wijziging maakt het secret dan niet onbruikbaar.
  # Measured-boot-binding is een aparte, latere hardening-stap
  # (docs/ATTESTATION.md § toestelklassen).
  if [ -s "$SECRET" ]; then
    systemd-creds encrypt --with-key=tpm2 --tpm2-pcrs="" --name="$CRED_NAME" "$SECRET" "$CRED"
    shred -u "$SECRET"
    echo "coolbx-gen-device-secret: bestaand secret TPM2-geseald (upgrade); plaintext vernietigd"
  else
    head -c32 /dev/urandom | base64 -w0 | \
      systemd-creds encrypt --with-key=tpm2 --tpm2-pcrs="" --name="$CRED_NAME" - "$CRED"
    echo "coolbx-gen-device-secret: nieuw secret gegenereerd en TPM2-geseald ($CRED)"
  fi
  chmod 0600 "$CRED"
  chown root:root "$CRED"
  echo tpm-sealed > "$CLASS"
else
  if [ ! -s "$SECRET" ]; then
    head -c32 /dev/urandom | base64 -w0 > "$SECRET"
    chmod 0600 "$SECRET"
    chown root:root "$SECRET"
    echo "coolbx-gen-device-secret: nieuw per-toestel-secret aangemaakt ($SECRET, 0600 root)"
  fi
  echo file-secret > "$CLASS"
  echo "coolbx-gen-device-secret: geen TPM2 — Tier 2 file-secret (server kan dit weren via EXAM_MIN_DEVICE_CLASS)"
fi
chmod 0644 "$CLASS"
