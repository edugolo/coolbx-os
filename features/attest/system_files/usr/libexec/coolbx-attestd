#!/usr/bin/env python3
"""Coolbx OS — root signing-daemon voor toestel-attestatie (ADR-0013/0024).

Houdt het per-toestel-secret (root-only /etc/coolbx/device-secret) en tekent challenges met
HMAC-SHA256, ZONDER het secret ooit te lekken. Lokale clients (de native-messaging-host) sturen
{"challenge": "<server-nonce>"} over een unix-socket en krijgen {"deviceId", "session", "signature"}.

De **session**-claim (kiosk vs free) wordt bepaald via SO_PEERCRED — de UID van het verbindende
proces, door de kernel bepaald, NIET door de aanroeper. Draait de aanroep onder de coolbx-kiosk-user
→ session=kiosk; anders → session=free. De claim wordt MEEGETEKEND in de HMAC
(sig = HMAC(secret, nonce + "|" + session)) zodat hij onvervalsbaar is. De Focus-server vereist
session=kiosk voor een proctored toets. Zie docs/ATTESTATION.md.
"""
import hashlib
import hmac
import json
import os
import pwd
import socket
import socketserver
import struct
import subprocess

SECRET_PATH = "/etc/coolbx/device-secret"
CRED_PATH = "/etc/coolbx/device-secret.cred"
CRED_NAME = "coolbx-device-secret"
SOCK_PATH = "/run/coolbx-attest.sock"
KIOSK_USER = "coolbx-kiosk"

_secret_cache = None


def load_secret():
    """Tier 1 (B3.e): TPM2-sealed credential — in-memory decrypt via
    systemd-creds; de plaintext raakt nooit de schijf. Tier 2: plain file
    (0600 root). Gecachet: het secret verandert alleen bij re-enrollment
    (dan herstart de daemon toch)."""
    global _secret_cache
    if _secret_cache:
        return _secret_cache
    if os.path.exists(CRED_PATH):
        try:
            proc = subprocess.run(
                ["systemd-creds", "decrypt", "--name=" + CRED_NAME, CRED_PATH, "-"],
                capture_output=True, timeout=15,
            )
        except Exception:
            return None
        if proc.returncode == 0 and proc.stdout.strip():
            _secret_cache = proc.stdout.strip()
        return _secret_cache
    try:
        _secret_cache = open(SECRET_PATH, "rb").read().strip() or None
    except OSError:
        return None
    return _secret_cache


def device_id():
    try:
        mid = open("/etc/machine-id").read().strip()
    except OSError:
        mid = ""
    # Stabiele, niet-omkeerbare toestel-ID (lekt de machine-id niet rechtstreeks).
    return hashlib.sha256(("coolbx:" + mid).encode()).hexdigest()[:32]


def peer_session(conn):
    """Bepaal de sessie uit de UID van het verbindende proces (SO_PEERCRED, door de kernel
    bepaald). coolbx-kiosk-user → 'kiosk'; al de rest → 'free'. Onvervalsbaar door de aanroeper."""
    try:
        creds = conn.getsockopt(socket.SOL_SOCKET, socket.SO_PEERCRED, struct.calcsize("3i"))
        _pid, uid, _gid = struct.unpack("3i", creds)
        name = pwd.getpwuid(uid).pw_name
    except Exception:
        return "free"
    return "kiosk" if name == KIOSK_USER else "free"


EXAM_POLICY_BIN = "/usr/libexec/coolbx-exam-policy"


def apply_exam_policy(payload, session):
    """Per-examen kiosk-policy (B3.c, F-03-007). ALLEEN de kiosk-sessie mag dit
    vragen (SO_PEERCRED, kernel-bepaald) — de vrije modus of een ssh-gebruiker
    kan de browser-policy dus niet zetten. phase 'exam' schrijft baseline ∪
    server-domeinen; 'lobby' herstelt de default-deny lobby-baseline. De
    policy-writer valideert de domeinen en herstart de kiosk-Chromium."""
    if session != "kiosk":
        return {"error": "exam policy alleen vanuit de kiosk-sessie"}
    phase = payload.get("phase")
    if phase not in ("exam", "lobby"):
        return {"error": "ongeldige phase"}
    cmd = [EXAM_POLICY_BIN, "apply" if phase == "exam" else "lobby", "--restart"]
    try:
        proc = subprocess.run(
            cmd,
            input=json.dumps({"allowDomains": payload.get("allowDomains", [])}),
            capture_output=True,
            text=True,
            timeout=30,
        )
    except Exception as e:
        return {"error": "policy-writer faalde: %s" % e}
    if proc.returncode != 0:
        return {"error": "policy-writer weigerde: %s" % proc.stderr.strip()[:200]}
    return {"ok": True, "phase": phase}


class Handler(socketserver.StreamRequestHandler):
    def handle(self):
        line = self.rfile.readline()
        try:
            req = json.loads(line.decode("utf-8"))
        except Exception:
            self.wfile.write(b'{"error":"bad request"}\n')
            return
        session = peer_session(self.connection)

        # Per-examen kiosk-policy (B3.c) — geen secret nodig; wel kiosk-peer.
        if isinstance(req.get("examPolicy"), dict):
            out = json.dumps(apply_exam_policy(req["examPolicy"], session))
            self.wfile.write((out + "\n").encode("utf-8"))
            return

        secret = load_secret()
        if not secret:
            self.wfile.write(b'{"error":"no device secret"}\n')
            return
        challenge = str(req.get("challenge", ""))
        if not challenge:
            self.wfile.write(b'{"error":"empty challenge"}\n')
            return
        # De session-claim mee-tekenen → de server kan een gefakete claim niet accepteren.
        msg = (challenge + "|" + session).encode("utf-8")
        sig = hmac.new(secret, msg, hashlib.sha256).hexdigest()
        out = json.dumps({"deviceId": device_id(), "session": session, "signature": sig})
        self.wfile.write((out + "\n").encode("utf-8"))


class Server(socketserver.ThreadingUnixStreamServer):
    daemon_threads = True
    allow_reuse_address = True


def main():
    if os.path.exists(SOCK_PATH):
        os.unlink(SOCK_PATH)
    srv = Server(SOCK_PATH, Handler)
    # De socket mag door de kiosk-user bereikbaar zijn (tekenen = toegestane operatie);
    # het secret blijft in dit root-proces. Geen secret-exfiltratie mogelijk.
    os.chmod(SOCK_PATH, 0o666)
    srv.serve_forever()


if __name__ == "__main__":
    main()
