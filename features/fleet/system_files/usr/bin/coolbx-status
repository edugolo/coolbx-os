#!/usr/bin/env bash
# Coolbx OS — toestelstatus voor schoolIT (Fase 8, observability). Lokaal, geen open poort:
# één overzicht van OS-deployment, boot-gezondheid, update-stand, kiosk-gereedheid en toestel-ID.
# (Web-beheer via Cockpit = optioneel + firewall-naar-schoolnet; bewust niet standaard aan.)
set -uo pipefail

bold() { printf '\033[1m%s\033[0m\n' "$1"; }
line() { printf '  %-22s %s\n' "$1" "$2"; }

bold "Coolbx OS — toestelstatus"

# OS-deployment (bootc) — image + of er een echte update gestaged is (json, geen grep-heuristiek)
booted="$(bootc status --format json 2>/dev/null | python3 -c 'import sys,json;
d=json.load(sys.stdin); print((d.get("status",{}).get("booted") or {}).get("image",{}).get("image",{}).get("image","onbekend"))' 2>/dev/null)"
line "OS-image" "${booted:-onbekend}"
staged="$(bootc status --format json 2>/dev/null | python3 -c 'import sys,json;
print("JA — actief bij volgende reboot" if (json.load(sys.stdin).get("status",{}).get("staged")) else "nee")' 2>/dev/null)"
line "Update gestaged" "${staged:-onbekend}"

# Boot-gezondheid (greenboot) — is-active print de staat zelf; geen '|| echo' (zou dubbel printen)
motd="$(cat /etc/motd.d/boot-status 2>/dev/null | tr -d '\n' | head -c 60)"
gb="$(systemctl is-active greenboot-healthcheck.service 2>/dev/null)"
line "Boot-status" "${motd:-${gb:-n/a}}"

# Auto-update
line "Update-timer" "$(systemctl is-enabled coolbx-update.timer 2>/dev/null || echo ?) ($(systemctl is-active coolbx-update.timer 2>/dev/null || echo ?))"
nextrun="$(systemctl list-timers coolbx-update.timer --no-legend 2>/dev/null | awk '{print $1, $2}')"
line "Volgende update" "${nextrun:-onbekend}"

# Kiosk / Focus-gereedheid (lokaal, géén focus-api-call)
line "Kiosk-launcher" "$(test -x /usr/bin/coolbx-kiosk-start && echo aanwezig || echo ONTBREEKT)"
line "Focus-extensie-policy" "$(test -f /etc/chromium/policies/managed/coolbx-managed.json && echo aanwezig || echo ONTBREEKT)"

# Toestel-attestatie
line "Attestatie-daemon" "$(systemctl is-active coolbx-attestd.service 2>/dev/null || echo n/a)"
did=""
[ -r /etc/coolbx/device-secret ] && did="$(python3 -c 'import hashlib;print(hashlib.sha256(("coolbx:"+open("/etc/machine-id").read().strip()).encode()).hexdigest()[:32])' 2>/dev/null)"
line "Toestel-ID" "${did:-(enkel als root leesbaar)}"

# Gefaalde units (rode vlag)
failed="$(systemctl --failed --no-legend --plain 2>/dev/null | wc -l)"
line "Gefaalde units" "${failed}"
